<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress verbose SDK / cloud provider logs during the e2e run -->
    <logger name="com.azure"                         level="WARN"/>
    <logger name="software.amazon"                   level="WARN"/>
    <logger name="com.google.cloud"                  level="WARN"/>
    <logger name="io.grpc"                           level="WARN"/>
    <logger name="io.netty"                          level="WARN"/>
    <logger name="reactor"                           level="WARN"/>
    <logger name="org.apache.http"                   level="WARN"/>

    <!-- Multicloud DB SDK diagnostic logs (set to DEBUG when troubleshooting) -->
    <logger name="com.multiclouddb"                  level="INFO"/>

    <!-- Application logs -->
    <logger name="com.microsoft.multiclouddb.e2e"    level="DEBUG"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
